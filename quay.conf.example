# quay.conf — copy to quay.conf, fill in, then run install.sh

DISK="/dev/nvme0n1"
HOSTNAME="quay"
TIMEZONE="UTC"

# networking: hot-swappable dual-stack
# ethernet is prioritized when plugged in; system fails over to wifi seamlessly.
ETH_NIC="eth0"
WIFI_NIC="wlan0"

# wifi credentials (optional)
WIFI_SSID=""
WIFI_PSK=""

# required
LUKS_PASSWORD=""
ROOT_PASSWORD=""  # console access — mandatory even if you use SSH keys

# recommended: SSH key for remote access
SSH_PUBKEY=""     # paste your full ssh-ed25519 ... line

# hypervisor tuning — leave blank to skip
ISOLCPUS=""       # cores to isolate for vms (e.g. "2-7")
HUGEPAGES="512"   # 2MB hugepages (512 = 1GB preallocated)
VFIO_IDS=""       # pci ids for passthrough (e.g. "10de:2684,10de:228b")

# secure boot signing — requires keys in /etc/quay/
SIGN_UKI=0
