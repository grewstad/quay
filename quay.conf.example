# quay.conf — copy to quay.conf, fill in, then run install.sh

DISK="/dev/nvme0n1"
HOSTNAME="quay"
TIMEZONE="UTC"
ETH_NIC="eth0"

# required
LUKS_PASSWORD=""
ROOT_PASSWORD=""

# recommended: ssh key for remote access
SSH_PUBKEY=""

# wifi fallback (optional, desktop use)
WIFI_NIC=""
WIFI_SSID=""
WIFI_PSK=""

# hypervisor tuning — leave blank to skip
ISOLCPUS=""       # cores to isolate for vms (e.g. "2-7")
HUGEPAGES="512"   # 2MB hugepages (512 = 1GB)
VFIO_IDS=""       # pci ids for passthrough (e.g. "10de:2684,10de:228b")

# secure boot — requires keys in /etc/quay/
SIGN_UKI=0
